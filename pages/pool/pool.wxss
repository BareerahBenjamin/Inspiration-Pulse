.pool-page {
  min-height: 100vh;
  background:
    radial-gradient(ellipse 500rpx 500rpx at 70% 10%, rgba(155, 186, 130, 0.04) 0%, transparent 60%),
    radial-gradient(ellipse 300rpx 400rpx at 20% 80%, rgba(196, 172, 110, 0.02) 0%, transparent 50%),
    linear-gradient(175deg, #1A2618 0%, #1D2B1A 35%, #203020 70%, #1A2618 100%);
  background-attachment: fixed;
  padding-bottom: 140rpx;
}

/* ── 录入区 ── */
.input-section {
  padding: 40rpx 32rpx 20rpx;
}

.input-bar {
  background: rgba(32, 48, 32, 0.6);
  border: 1rpx solid rgba(155, 186, 130, 0.06);
  border-radius: 20rpx;
  padding: 28rpx 30rpx;
  margin-bottom: 20rpx;
  transition: all 0.3s ease;
}

.input-bar:focus-within {
  border-color: rgba(155, 186, 130, 0.16);
  background: rgba(32, 48, 32, 0.75);
}

.idea-input {
  width: 100%;
  font-size: 32rpx;
  color: #E2E4D4;
  line-height: 1.65;
  min-height: 88rpx;
}

.input-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 14rpx;
  margin-top: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  font-weight: 500;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(155, 186, 130, 0.08);
  color: #7A9A68;
  background: rgba(155, 186, 130, 0.04);
  letter-spacing: 1rpx;
  transition: all 0.2s ease;
}

.action-btn.recording {
  border-color: rgba(196, 172, 110, 0.2);
  color: #C4AC6E;
  background: rgba(196, 172, 110, 0.06);
}

.action-btn.primary {
  background: #9BBA82;
  color: #1A2618;
  border-color: transparent;
  box-shadow: 0 4rpx 14rpx rgba(155, 186, 130, 0.18);
  font-weight: 600;
}

.action-btn.disabled {
  opacity: 0.25;
  box-shadow: none;
}

/* 快捷标签 */
.tag-scroll {
  white-space: nowrap;
}

.tag-row {
  display: flex;
  gap: 12rpx;
  padding: 4rpx 0;
}

.quick-tag {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 500;
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(155, 186, 130, 0.06);
  color: #5A7A48;
  background: rgba(32, 48, 32, 0.35);
  flex-shrink: 0;
  letter-spacing: 1rpx;
  transition: all 0.2s ease;
}

.quick-tag:active {
  transform: scale(0.95);
}

.quick-tag.active {
  background: rgba(155, 186, 130, 0.1);
  color: #9BBA82;
  border-color: rgba(155, 186, 130, 0.18);
}

/* ── 筛选栏 ── */
.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
}

.pool-count {
  font-size: 24rpx;
  font-weight: 500;
  color: #4A6838;
  letter-spacing: 1rpx;
}

.filter-right {
  display: flex;
  gap: 10rpx;
}

.filter-chip {
  font-size: 24rpx;
  font-weight: 500;
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(155, 186, 130, 0.05);
  color: #4A6838;
  background: rgba(32, 48, 32, 0.25);
  letter-spacing: 1rpx;
  transition: all 0.2s ease;
}

.filter-chip.active {
  background: rgba(155, 186, 130, 0.1);
  color: #9BBA82;
  border-color: rgba(155, 186, 130, 0.15);
}

/* ── 灵感卡片 ── */
.ideas-list {
  padding: 0 28rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.idea-card {
  background: rgba(32, 48, 32, 0.55);
  border-radius: 16rpx;
  border: 1rpx solid rgba(155, 186, 130, 0.05);
  padding: 26rpx 28rpx;
  transition: all 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.idea-card:active {
  transform: scale(0.985);
  background: rgba(32, 48, 32, 0.75);
}

.idea-card.converted {
  opacity: 0.3;
  border-color: transparent;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.card-tag-wrap {
  display: flex;
  gap: 10rpx;
  align-items: center;
}

.card-tag {
  font-size: 22rpx;
  font-weight: 500;
  color: #9BBA82;
  background: rgba(155, 186, 130, 0.07);
  border: 1rpx solid rgba(155, 186, 130, 0.12);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.card-ai-tag {
  font-size: 22rpx;
  font-weight: 500;
  color: #C4AC6E;
  background: rgba(196, 172, 110, 0.06);
  border: 1rpx solid rgba(196, 172, 110, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.card-deadline {
  font-size: 22rpx;
  font-weight: 500;
  color: #7AA0B0;
  background: rgba(122, 160, 176, 0.06);
  border: 1rpx solid rgba(122, 160, 176, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.card-deadline.urgent {
  color: #C87A5A;
  background: rgba(200, 122, 90, 0.06);
  border-color: rgba(200, 122, 90, 0.12);
}

.card-menu {
  font-size: 36rpx;
  color: #4A6838;
  padding: 0 8rpx;
  letter-spacing: 2rpx;
  line-height: 1;
  transition: color 0.15s ease;
}

.card-menu:active {
  color: #6A8858;
}

.card-content {
  font-size: 32rpx;
  color: #E2E4D4;
  line-height: 1.7;
  display: block;
  margin-bottom: 18rpx;
  font-weight: 400;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid rgba(155, 186, 130, 0.05);
  padding-top: 16rpx;
}

.card-time {
  font-size: 22rpx;
  color: #4A6838;
  font-weight: 400;
  letter-spacing: 1rpx;
}

.card-actions {
  display: flex;
  gap: 12rpx;
}

.card-btn {
  font-size: 22rpx;
  font-weight: 500;
  color: #7A9A68;
  border: 1rpx solid rgba(155, 186, 130, 0.07);
  background: rgba(155, 186, 130, 0.03);
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  transition: all 0.2s ease;
}

.card-btn:active {
  transform: scale(0.95);
  background: rgba(155, 186, 130, 0.06);
}

.card-btn.done {
  color: #4A6838;
  border-color: transparent;
  background: transparent;
}

/* ── 空状态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  gap: 24rpx;
}

.empty-icon {
  font-size: 96rpx;
}

.empty-text {
  font-size: 28rpx;
  font-weight: 400;
  color: #4A6838;
  text-align: center;
  line-height: 2;
  white-space: pre-line;
  letter-spacing: 1rpx;
}

/* ── 操作菜单 ── */
.menu-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.menu-sheet {
  width: 100%;
  background: rgba(26, 38, 24, 0.97);
  backdrop-filter: blur(24rpx);
  border-radius: 24rpx 24rpx 0 0;
  padding: 16rpx 0 60rpx;
  border-top: 1rpx solid rgba(155, 186, 130, 0.08);
}

.menu-item {
  padding: 34rpx 44rpx;
  font-size: 30rpx;
  font-weight: 400;
  color: #C87A5A;
  border-bottom: 1rpx solid rgba(155, 186, 130, 0.04);
}

.menu-item.cancel {
  color: #6A8858;
  border: none;
}
