.index-page {
  min-height: 100vh;
  background:
    radial-gradient(ellipse 600rpx 500rpx at 30% 0%, rgba(155, 186, 130, 0.05) 0%, transparent 70%),
    radial-gradient(ellipse 400rpx 400rpx at 80% 70%, rgba(139, 154, 107, 0.03) 0%, transparent 60%),
    linear-gradient(175deg, #1A2618 0%, #1D2B1A 35%, #203020 65%, #1A2618 100%);
  background-attachment: fixed;
  padding-bottom: 200rpx;
}

/* ── 顶部 header ── */
.header {
  padding: 72rpx 36rpx 28rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.eyebrow {
  font-size: 22rpx;
  font-weight: 500;
  color: #5A7A48;
  letter-spacing: 8rpx;
  text-transform: uppercase;
  display: block;
  margin-bottom: 10rpx;
}

.page-title {
  font-size: 84rpx;
  font-weight: 300;
  color: #E2E4D4;
  letter-spacing: 8rpx;
  display: block;
  line-height: 1.1;
}

.lv-chip {
  background: rgba(155, 186, 130, 0.07);
  border: 1rpx solid rgba(155, 186, 130, 0.1);
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  text-align: center;
  min-width: 100rpx;
}

.lv-num {
  font-size: 48rpx;
  font-weight: 300;
  color: #9BBA82;
  display: block;
  line-height: 1;
}

.lv-txt {
  font-size: 18rpx;
  font-weight: 500;
  color: #5A7A48;
  letter-spacing: 4rpx;
  display: block;
  margin-top: 8rpx;
}

.prog-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 36rpx;
}

.prog-track {
  flex: 1;
  height: 4rpx;
  background: rgba(155, 186, 130, 0.08);
  border-radius: 2rpx;
  overflow: hidden;
}

.prog-fill {
  height: 4rpx;
  background: linear-gradient(90deg, #6A8858, #9BBA82);
  border-radius: 2rpx;
  transition: width 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.prog-txt {
  font-size: 22rpx;
  font-weight: 500;
  color: #5A7A48;
  min-width: 64rpx;
  text-align: right;
  letter-spacing: 1rpx;
}

/* ── 能量选择器 ── */
.energy-section {
  padding: 20rpx 32rpx 16rpx;
}

.energy-row {
  display: flex;
  gap: 14rpx;
}

.en-btn {
  flex: 1;
  border-radius: 16rpx;
  padding: 30rpx 0 24rpx;
  text-align: center;
  border: 1rpx solid rgba(155, 186, 130, 0.06);
  background: rgba(32, 48, 32, 0.4);
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.en-btn.active {
  border-color: rgba(155, 186, 130, 0.18);
  background: rgba(32, 48, 32, 0.8);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-2rpx);
}

.en-icon {
  font-size: 44rpx;
  display: block;
  line-height: 1;
}

.en-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #6A8858;
  display: block;
  margin-top: 14rpx;
  letter-spacing: 2rpx;
}

.en-btn.active .en-label {
  color: #9BBA82;
}

/* ── section label ── */
.sec-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #5A7A48;
  letter-spacing: 6rpx;
  text-transform: uppercase;
  padding: 40rpx 36rpx 20rpx;
  display: block;
}

/* ── 任务卡片 ── */
.task-list {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.task-card {
  background: rgba(32, 48, 32, 0.55);
  border-radius: 16rpx;
  border: 1rpx solid rgba(155, 186, 130, 0.05);
  padding: 30rpx 30rpx;
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.task-card.active {
  background: rgba(32, 48, 32, 0.85);
  border-color: rgba(155, 186, 130, 0.14);
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.1);
}

.task-card.done {
  opacity: 0.3;
  border-color: transparent;
}

.task-num {
  font-size: 28rpx;
  font-weight: 300;
  color: #4A6838;
  min-width: 52rpx;
  padding-top: 6rpx;
  letter-spacing: 1rpx;
}

.task-card.active .task-num {
  color: #9BBA82;
}

.task-body {
  flex: 1;
}

.task-content {
  font-size: 32rpx;
  color: #E2E4D4;
  display: block;
  line-height: 1.7;
  margin-bottom: 10rpx;
  font-weight: 400;
}

.task-meta {
  margin-bottom: 14rpx;
}

.task-deadline {
  font-size: 22rpx;
  font-weight: 500;
  color: #7AA0B0;
  letter-spacing: 1rpx;
}

.task-deadline.urgent {
  color: #C87A5A;
}

.task-btns {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.task-btn {
  font-size: 24rpx;
  font-weight: 500;
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(155, 186, 130, 0.1);
  color: #7A9A68;
  background: rgba(155, 186, 130, 0.04);
  letter-spacing: 1rpx;
  transition: all 0.2s ease;
}

.task-btn:active {
  transform: scale(0.95);
  background: rgba(155, 186, 130, 0.08);
}

.task-btn.go {
  border-color: transparent;
  color: #1A2618;
  background: #9BBA82;
  box-shadow: 0 4rpx 14rpx rgba(155, 186, 130, 0.18);
  font-weight: 600;
}

.task-btn.go:active {
  background: #8AAA72;
}

.task-skip {
  font-size: 24rpx;
  font-weight: 400;
  color: #4A6838;
  padding: 8rpx 14rpx;
  transition: color 0.15s ease;
}

.task-skip:active {
  color: #6A8858;
}

/* ── 空状态 ── */
.empty-task {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 0 40rpx;
  gap: 24rpx;
}

.empty-icon {
  font-size: 100rpx;
  line-height: 1;
}

.empty-text {
  font-size: 28rpx;
  font-weight: 400;
  color: #5A7A48;
  text-align: center;
  line-height: 2;
  white-space: pre-line;
  letter-spacing: 1rpx;
}

.go-pool-btn {
  margin-top: 20rpx;
  padding: 28rpx 72rpx;
  background: #9BBA82;
  color: #1A2618;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 3rpx;
  box-shadow: 0 6rpx 24rpx rgba(155, 186, 130, 0.18);
  transition: all 0.2s ease;
}

.go-pool-btn:active {
  transform: scale(0.96);
}
