.profile-page {
  min-height: 100vh;
  background:
    radial-gradient(ellipse 500rpx 500rpx at 50% 0%, rgba(155, 186, 130, 0.05) 0%, transparent 60%),
    linear-gradient(175deg, #1A2618 0%, #1D2B1A 40%, #203020 70%, #1A2618 100%);
  background-attachment: fixed;
  padding-bottom: 200rpx;
}

/* ── 登录区 ── */
.login-section {
  padding: 120rpx 40rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.login-eyebrow {
  font-size: 22rpx;
  font-weight: 500;
  color: #4A6838;
  letter-spacing: 8rpx;
  text-transform: uppercase;
  display: block;
  margin-bottom: 16rpx;
}

.login-title {
  font-size: 52rpx;
  font-weight: 300;
  color: #E2E4D4;
  letter-spacing: 6rpx;
  display: block;
  margin-bottom: 16rpx;
}

.login-desc {
  font-size: 26rpx;
  font-weight: 400;
  color: #5A7A48;
  letter-spacing: 2rpx;
  display: block;
}

.login-form {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  background: rgba(32, 48, 32, 0.5);
  border: 2rpx dashed rgba(155, 186, 130, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.avatar-plus {
  font-size: 52rpx;
  color: #5A7A48;
  font-weight: 300;
  line-height: 1;
}

.avatar-hint {
  font-size: 20rpx;
  color: #5A7A48;
  letter-spacing: 1rpx;
}

.nick-input {
  width: 100%;
  padding: 28rpx 30rpx;
  background: rgba(32, 48, 32, 0.5);
  border: 1rpx solid rgba(155, 186, 130, 0.08);
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #E2E4D4;
  text-align: center;
  letter-spacing: 1rpx;
}

.nick-placeholder {
  color: #4A6838;
}

.login-btn {
  width: 100%;
  padding: 30rpx;
  background: #9BBA82;
  color: #1A2618;
  border-radius: 16rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 24rpx rgba(155, 186, 130, 0.16);
  transition: all 0.2s ease;
}

.login-btn:active {
  transform: scale(0.97);
}

.login-btn.disabled {
  opacity: 0.25;
  box-shadow: none;
}

/* ── 用户区 ── */
.user-section {
  padding: 60rpx 32rpx;
}

.user-header {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 48rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(155, 186, 130, 0.15);
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 500;
  color: #E2E4D4;
  letter-spacing: 2rpx;
}

.user-joined {
  font-size: 22rpx;
  color: #5A7A48;
  letter-spacing: 2rpx;
}

/* 统计 */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.stat-card {
  flex: 1;
  background: rgba(32, 48, 32, 0.5);
  border: 1rpx solid rgba(155, 186, 130, 0.06);
  border-radius: 16rpx;
  padding: 32rpx 0;
  text-align: center;
}

.stat-num {
  font-size: 52rpx;
  font-weight: 300;
  color: #9BBA82;
  display: block;
  line-height: 1;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #5A7A48;
  letter-spacing: 2rpx;
  font-weight: 500;
}

/* 设置 */
.settings-section {
  border-top: 1rpx solid rgba(155, 186, 130, 0.06);
  padding-top: 16rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 8rpx;
  border-bottom: 1rpx solid rgba(155, 186, 130, 0.04);
  transition: background 0.15s ease;
}

.setting-item:active {
  background: rgba(155, 186, 130, 0.04);
}

.setting-label {
  font-size: 30rpx;
  color: #C87A5A;
  font-weight: 400;
  letter-spacing: 1rpx;
}

.setting-arrow {
  font-size: 32rpx;
  color: #4A6838;
  font-weight: 300;
}
