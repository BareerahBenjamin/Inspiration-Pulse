<view class="profile-page">

<!-- 未登录 -->
<view class="login-section" wx:if="{{!isLoggedIn}}">
  <view class="login-header">
    <text class="login-eyebrow">inspiration pulse</text>
    <text class="login-title">欢迎来到灵感脉冲</text>
    <text class="login-desc">记录灵感，拆解行动，按能量执行</text>
  </view>

  <view class="login-form">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="avatar-preview" wx:if="{{avatarUrl}}" src="{{avatarUrl}}" mode="aspectFill"/>
      <view class="avatar-placeholder" wx:else>
        <text class="avatar-plus">+</text>
        <text class="avatar-hint">选择头像</text>
      </view>
    </button>

    <input
      class="nick-input"
      type="nickname"
      placeholder="输入昵称"
      placeholder-class="nick-placeholder"
      value="{{nickName}}"
      bindinput="onNickInput"
    />

    <view class="login-btn {{avatarUrl && nickName ? '' : 'disabled'}}" bindtap="onLogin">
      开启灵感之旅
    </view>
  </view>
</view>

<!-- 已登录 -->
<view class="user-section" wx:else>
  <!-- 用户信息 -->
  <view class="user-header">
    <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"/>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName}}</text>
      <text class="user-joined">灵感探索者</text>
    </view>
  </view>

  <!-- 统计 -->
  <view class="stats-row">
    <view class="stat-card">
      <text class="stat-num">{{stats.totalIdeas}}</text>
      <text class="stat-label">灵感</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{stats.doneTasks}}</text>
      <text class="stat-label">已完成</text>
    </view>
  </view>

  <!-- 设置 -->
  <view class="settings-section">
    <view class="setting-item" bindtap="onLogout">
      <text class="setting-label">退出登录</text>
      <text class="setting-arrow">›</text>
    </view>
  </view>
</view>

</view>
