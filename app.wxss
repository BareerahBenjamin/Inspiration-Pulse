page {
  background: #1A2618;
  color: #E2E4D4;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

/* ── 调色板 ── */
.bg       { background: #1A2618; }
.bg2      { background: #203020; }
.bg3      { background: #283A26; }
.acc-bg   { background: rgba(155, 186, 130, 0.06); }
.acc-bg2  { background: rgba(196, 172, 110, 0.04); }

.text     { color: #E2E4D4; }
.text2    { color: #9BBA82; }
.text3    { color: #6A8858; }
.accent   { color: #9BBA82; }
.accent2  { color: #C4AC6E; }
.green    { color: #9BBA82; }

/* ── 通用卡片 ── */
.card {
  background: rgba(32, 48, 32, 0.8);
  border-radius: 16rpx;
  border: 1rpx solid rgba(155, 186, 130, 0.08);
  padding: 28rpx 30rpx;
}

.card-active {
  border-color: rgba(155, 186, 130, 0.15);
  background: rgba(32, 48, 32, 0.95);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.12);
}
